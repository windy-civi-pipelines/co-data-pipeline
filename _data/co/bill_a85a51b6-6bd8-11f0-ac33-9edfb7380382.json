{"legislative_session": "2025A", "identifier": "SB25-142", "title": "Changes to Wildfire Resiliency Code Board", "from_organization": "~{\"classification\": \"upper\"}", "classification": ["bill"], "subject": [], "abstracts": [{"note": "summary", "abstract": "The act extends the time frame within which a governing body of a city, town, or city and county with jurisdiction in an area within the wildland-urban interface is required to adopt wildfire codes and standards that meet or exceed the wildfire resiliency code board's wildfire codes and standards from 3 to 9 months after the board's adoption of wildfire codes and standards.\n\nThe act allows a governing body to enter into a cooperative agreement with another entity, such as a third-party contractor or another governing body, in order to enforce wildfire codes and standards.\n(Note: This summary applies to this bill as enacted.)"}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "Governor Signed", "date": "2025-06-03T06:00:00+00:00", "organization_id": "~{\"classification\": \"executive\"}", "classification": ["executive-signature"], "related_entities": []}, {"description": "Signed by the Speaker of the House", "date": "2025-05-13T06:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": [], "related_entities": []}, {"description": "Signed by the President of the Senate", "date": "2025-05-13T06:00:00+00:00", "organization_id": "~{\"classification\": \"upper\"}", "classification": [], "related_entities": []}, {"description": "Sent to the Governor", "date": "2025-05-13T06:00:00+00:00", "organization_id": "~{\"classification\": \"executive\"}", "classification": ["executive-receipt"], "related_entities": []}, {"description": "House Third Reading Passed - No Amendments", "date": "2025-05-03T06:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["passage", "reading-3"], "related_entities": []}, {"description": "House Second 