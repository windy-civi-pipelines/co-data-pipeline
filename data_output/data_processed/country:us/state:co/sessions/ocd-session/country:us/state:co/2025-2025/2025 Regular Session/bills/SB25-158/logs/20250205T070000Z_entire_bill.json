{
  "legislative_session": "2025A",
  "identifier": "SB25-158",
  "title": "State Agency Procurement & Disposal Certain Items",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The act creates state procurement practices for firearms and items regulated pursuant to the federal \"National Firearms Act\" (\"NFA\"). The act applies to all contracts the state sources, enters into, awards, amends, renews, or extends on or after January 1, 2026, for procuring firearms or items regulated pursuant to the \"NFA\". During a governmental body's contracting process, sourcing method process, or upon request during the term of a contract, a contractor or bidder shall comply with certain requirements, make certain disclosures, and provide certain documentation to confirm that the contractor or bidder engages in safe business practices.\n\nThe attorney general may assist the department of personnel (department) in developing processes and procedures to implement the procurement practices.\n\nThe department may adopt rules to implement this act.\n(Note: This summary applies to this bill as enacted.)"
    }
  ],
